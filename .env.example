# =====================================================
# AgroConecta — Variáveis de Ambiente
# =====================================================
# Copie este ficheiro para .env.local e preencha com
# os valores do seu projeto. NUNCA faça commit do
# .env.local para o Git!
# =====================================================

# ── Firebase ──────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Admin ─────────────────────────────────────────────
# Email que terá automaticamente o papel 'admin' no primeiro login
VITE_ADMIN_EMAIL=

# ── Google Gemini (Assistente IA) ─────────────────────
# Obtenha em: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# ── PaySuite (Pagamentos M-Pesa / eMola) ──────────────
# Registe-se em: https://app.paysuite.co.mz
# Use chave de TESTE (ps_test_...) durante o desenvolvimento
# e chave de PRODUÇÃO (ps_live_...) apenas em produção.
# Deixar em branco activa o modo de simulação (útil para dev).
VITE_PAYSUITE_API_KEY=
